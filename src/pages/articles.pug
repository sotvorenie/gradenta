extends ../components/layouts/base.pug

include ../components/common/section-title
include ../components/common/media-center-tabs

block title
    | Статьи

block hero
    +hero('', false)

    block banner-content


block content
    section.media-center.section
        div.media-center__inner.section__inner.container
            +section-title('Медиацентр')

            +media-center-tabs(2)

            ul.articles__list
                each item in mediaCenterItems
                    li.articles__item.flex.flex-align-center.position-relative
                        div.articles__img-container.img-container
                            img(src=item.img)

                        div.articles__right.flex.flex-align-center.flex-justify-between
                            div.articles__info.text-w700.h6
                                p.articles__date= item.date
                                p.articles__title= item.title

                            a(href="#").articles__link.flex-center Читать

            button(type="button").media-center__btn.flex-center.text-w700 Смотреть еще